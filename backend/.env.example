# Database
DATABASE_URL="postgresql://user:password@localhost:5432/clinocash?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Encryption
AES_ENCRYPTION_KEY="your-32-byte-encryption-key-here"

# OTP
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3

# Payment Gateways
PAYSTACK_SECRET_KEY="sk_test_xxx"
PAYSTACK_PUBLIC_KEY="pk_test_xxx"
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-xxx"
FLUTTERWAVE_PUBLIC_KEY="FLWPUBK_TEST-xxx"
HUBTEL_CLIENT_ID="xxx"
HUBTEL_CLIENT_SECRET="xxx"

# Bank of Ghana — Emtech Regulatory Sandbox (v2.0)
# Get credentials from: bog.gh.app.emtech.com → Applications → Your App
EMTECH_BASE_URL=https://api.emtech.com/integration
EMTECH_TOKEN_URL=https://platform.com/finapp/api/v1/auth/token
EMTECH_CLIENT_ID=
EMTECH_CLIENT_SECRET=

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
